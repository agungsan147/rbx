-- Start
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")
local VIM = game:GetService("VirtualInputManager")

-- Remote
local remote = ReplicatedStorage:WaitForChild("Shared")
    :WaitForChild("Universe")
    :WaitForChild("Network")
    :WaitForChild("RemoteEvent")
    :WaitForChild("Actionable")

-- State
local ENABLED = false
local RUNNING = false

-- Range ID
local START_ID = 1200
local END_ID = 2100

-- Durasi
local FARM_TIME = 180 -- 3 menit

-- Fungsi
local function startAutoFarm()
    if RUNNING then
        return
    end

    RUNNING = true

    task.spawn(function()
        local startTime = tick()

        while ENABLED do
            -- cek timer
            if tick() - startTime >= FARM_TIME then
                print("Waktu habis, reset karakter")

                ENABLED = false

                local char = player.Character
                if char then
                    char:BreakJoints()
                end

                break
            end

            -- loop ID
            for i = START_ID, END_ID do
                if not ENABLED then
                    break
                end

                remote:FireServer(i)
                task.wait(0.02)
            end

            task.wait(0.2)
        end

        RUNNING = false
    end)
end

task.spawn(function()
    while true do
        task.wait(1)

        local gui = player:FindFirstChild("PlayerGui")
        if not gui then
            continue
        end

        for _, v in pairs(gui:GetDescendants()) do
            if v:IsA("TextButton") then
                local text = v.Text and v.Text:lower() or ""

                if text:find("play again") then
                    print("Ditemukan tombol:", v.Text)

                    if v.Visible and v.AbsoluteSize.X > 0 then
                        -- posisi klik (lebih ke bawah)
                        local pos = v.AbsolutePosition + Vector2.new(v.AbsoluteSize.X / 2, v.AbsoluteSize.Y * 1)

                        VIM:SendMouseButtonEvent(pos.X, pos.Y, 0, true, game, 0)
                        VIM:SendMouseButtonEvent(pos.X, pos.Y, 0, false, game, 0)

                        print("Klik di:", pos)

                        task.wait(5)
                    end
                end
            end
        end
    end
end)

-- UI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 220, 0, 80)
frame.Position = UDim2.new(0.5, -110, 0, 20)
frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
frame.BorderSizePixel = 0

local corner = Instance.new("UICorner", frame)
corner.CornerRadius = UDim.new(0, 12)

-- Title
local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1, 0, 0, 30)
title.BackgroundTransparency = 1
title.Text = "Auto Farm"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Font = Enum.Font.GothamBold
title.TextSize = 15

-- Button
local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(0.8, 0, 0, 35)
button.Position = UDim2.new(0.1, 0, 0.5, -5)
button.Text = "START"
button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
button.TextColor3 = Color3.new(1, 1, 1)
button.Font = Enum.Font.GothamBold
button.TextSize = 13

local btnCorner = Instance.new("UICorner", button)
btnCorner.CornerRadius = UDim.new(0, 10)

-- Drag UI
local dragging = false
local dragStart
local startPos

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position =
            UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Update UI
local function updateUI()
    if not button or not button.Parent then
        return
    end

    if ENABLED then
        button.Text = "STOP"
        button.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    else
        button.Text = "START"
        button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    end
end

button.MouseButton1Click:Connect(function()
    ENABLED = not ENABLED
    updateUI()
    if ENABLED then
        startAutoFarm()
    end
end)

-- Auto Start
task.delay(5, function()
    ENABLED = true
    updateUI()
    startAutoFarm()
end)
